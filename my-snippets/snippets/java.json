{
  "class comment": {
    "prefix": "/**c",
    "body": ["/**", " * ${1:description}", " *", " * @author: ${2:author}", " * @date: ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}", " */"],
    "description": "Create class comment"
  },
  "method comment": {
    "prefix": "/**m",
    "body": ["/**", " * ${1:description}", " */"],
    "description": "Create method comment"
  },
  "enum": {
    "prefix": "enum",
    "body": ["public enum ${TM_FILENAME_BASE} {", "\t$0", "}"],
    "description": "Public enum"
  },
  "interface": {
    "prefix": "interface",
    "body": ["public interface ${TM_FILENAME_BASE} {", "\t$0", "}"],
    "description": "Public interface"
  }
}
